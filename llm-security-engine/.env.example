# Local LLM Security Engine — Environment Configuration
# Copy this file to .env and adjust values for your local setup.

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini
OLLAMA_TIMEOUT=60

# ── Service ───────────────────────────────────────────────────────────────────
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# ── Authentication ────────────────────────────────────────────────────────────
# Optional. If set, all /analyze-* endpoints require header: X-API-Key: <value>
# Leave empty or unset to disable auth (safe for local-only development).
# LOCAL_LLM_API_KEY=your-secret-key-here

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Input Size Limits ─────────────────────────────────────────────────────────
MAX_DESCRIPTION_LENGTH=4000
MAX_CONTEXT_LENGTH=4000
MAX_PROMPT_LENGTH=8000
MAX_FIELD_LENGTH=500

# Local LLM Security Engine — Environment Configuration
# Copy this file to .env and adjust values for your local setup.

# ── Model (change this to switch models — no code changes needed) ─────────────
#
# The model is a runtime variable, not a compile-time setting.
# Pull a model once with:   ollama pull <model-name>
# Then update OLLAMA_MODEL below and restart the server.
#
# Starter models — run on most machines, no GPU required:
#   phi4-mini      ~3 GB RAM   fast, good accuracy    ← default for development
#   phi4           ~9 GB RAM   better accuracy, still CPU-friendly
#   mistral        ~5 GB RAM   fast and reliable general-purpose
#   llama3.1:8b    ~8 GB RAM   excellent accuracy on CPU
#
# Production models — dedicated GPU server recommended:
#   llama3.1:70b   ~43 GB RAM  best accuracy
#   llama3.3:70b   ~43 GB RAM  latest generation, high accuracy
#   qwen2.5:72b    ~45 GB RAM  strong multilingual + security reasoning
#
# Rule of thumb: larger model = more RAM + slower response, but more
# reliable threat classification and fewer hallucinated categories.
#
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini
OLLAMA_TIMEOUT=60

# ── Service ───────────────────────────────────────────────────────────────────
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# ── Authentication ────────────────────────────────────────────────────────────
# Optional. If set, all /analyze-* endpoints require header: X-API-Key: <value>
# Leave empty or unset to disable auth (safe for local-only development).
# LOCAL_LLM_API_KEY=your-secret-key-here

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Input Size Limits ─────────────────────────────────────────────────────────
MAX_DESCRIPTION_LENGTH=4000
MAX_CONTEXT_LENGTH=4000
MAX_PROMPT_LENGTH=8000
MAX_FIELD_LENGTH=500

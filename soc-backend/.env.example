# SOC API Server — Environment Configuration
# Copy this file to .env.local (or inject via environment) and adjust as needed.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Inbound authentication ────────────────────────────────────────────────────
# Protects POST /api/analyze with a shared secret.
# When set, callers must supply: X-API-Key: <value>
# When unset, authentication is disabled (useful in development).
# SOC_API_KEY=your-inbound-secret-key

# ── Rate limiting for /api/analyze ────────────────────────────────────────────
# Maximum requests per window per client IP.
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000

# ── LLM Provider Mode ─────────────────────────────────────────────────────────
# Controls which LLM provider the /api/analyze endpoint uses.
# Auto-detected from LOCAL_LLM_ENGINE_BASE_URL if not set explicitly.
#   local_security_engine — forward to the Local LLM Security Engine
#   none                  — no provider; /api/analyze returns 503
# PROVIDER_MODE=local_security_engine

# ── Local LLM Security Engine ─────────────────────────────────────────────────
# Required when PROVIDER_MODE=local_security_engine (or when base URL is set).
#
# Development (local machine):
LOCAL_LLM_ENGINE_BASE_URL=http://localhost:8000
#
# Development via Cloudflare Tunnel (remote SOC backend → local engine):
# LOCAL_LLM_ENGINE_BASE_URL=https://your-tunnel-name.trycloudflare.com
#
# Optional API key for the engine (must match the engine's LOCAL_LLM_API_KEY).
# LOCAL_LLM_ENGINE_API_KEY=your-engine-key

# Request timeout to the engine in milliseconds (default: 90000 = 90s).
# Local Ollama inference can take 30-60s on a mid-range CPU.
# LOCAL_LLM_ENGINE_TIMEOUT_MS=90000

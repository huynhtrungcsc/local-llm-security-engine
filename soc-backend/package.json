{
  "name": "soc-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx/esm --test tests/localSecurityEngine.test.ts tests/analyzeRoute.test.ts tests/contract.test.ts tests/e2e.test.ts"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16.4.7",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0"
  }
}
